# Copernicus Marine Service credentials
# Copy this file to .env and fill in your credentials.
# Register at: https://marine.copernicus.eu
COPERNICUSMARINE_SERVICE_USERNAME=your_email@example.com
COPERNICUSMARINE_SERVICE_PASSWORD=your_password
COPERNICUSMARINE_USERNAME=your_email@example.com
COPERNICUSMARINE_PASSWORD=your_password
